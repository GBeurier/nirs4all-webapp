            "description": "No derivative"
          },
          {
            "value": 1,
            "label": "First derivative",
            "description": "Rate of change"
          },
          {
            "value": 2,
            "label": "Second derivative",
            "description": "Curvature"
          }
        ],
        "description": "Derivative order (0=smoothing, 1=first, 2=second)",
