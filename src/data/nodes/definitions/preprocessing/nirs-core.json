        "type": "bool",
        "default": true,
        "description": "Scale spectra by dividing by the standard deviation",
        "isAdvanced": true
      },
      {
        "name": "ddof",
        "type": "int",
        "default": 0,
        "min": 0,
        "max": 1,
        "description": "Delta degrees of freedom for std calculation (0=population, 1=sample)",
        "isAdvanced": true
      }
