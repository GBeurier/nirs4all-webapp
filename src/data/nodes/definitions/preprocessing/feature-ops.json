[
  {
    "id": "preprocessing.pca",
    "name": "PCA",
    "type": "preprocessing",
    "classPath": "sklearn.decomposition.PCA",
    "description": "Principal Component Analysis",
    "longDescription": "Reduces dimensionality by projecting data onto principal components that capture maximum variance.",
    "category": "Dimensionality Reduction",
    "tags": [
      "pca",
      "decomposition",
      "dimensionality-reduction",
      "principal-components"
    ],
    "source": "sklearn",
    "parameters": [
      {
        "name": "n_components",
        "type": "int",
        "default": 10,
        "min": 1,
        "max": 500,
        "description": "Number of principal components to keep",
        "sweepable": true,
        "sweepPresets": [
          {
            "label": "Compact (1-10)",
            "type": "range",
            "values": {
              "from": 1,
              "to": 10,
              "step": 1
            }
          },
          {
            "label": "Standard (5-30)",
            "type": "range",
            "values": {
              "from": 5,
              "to": 30,
              "step": 5
            }
          }
        ],
        "finetunable": true,
        "finetuneType": "int",
        "finetuneRange": [
          1,
          50
        ]
      },
      {
        "name": "whiten",
        "type": "bool",
        "default": false,
        "description": "Whiten components to have unit variance",
        "isAdvanced": true
      },
      {
        "name": "svd_solver",
        "type": "select",
        "default": "auto",
        "options": [
          {
            "value": "auto",
            "label": "Auto"
          },
          {
            "value": "full",
            "label": "Full"
          },
          {
            "value": "randomized",
            "label": "Randomized"
          }
        ],
        "description": "SVD solver to use",
        "isAdvanced": true
      }
    ],
    "supportsParameterSweeps": true,
    "supportsStepGenerator": true,
    "supportsFinetuning": true,
    "legacyClassPaths": [
      "sklearn.decomposition._pca.PCA"
    ],
    "tier": "standard"
  },
