        "sweepable": true
      },
      {
        "name": "cv_folds",
        "type": "int",
        "default": 5,
        "min": 2,
        "max": 10,
        "description": "Number of cross-validation folds",
        "isAdvanced": true
      },
      {
        "name": "subset_ratio",
        "type": "float",
        "default": 0.8,
        "min": 0.5,
        "max": 1,
        "description": "Ratio of samples used in each iteration",
        "isAdvanced": true
      }
    ],
    "supportsParameterSweeps": true,
    "supportsStepGenerator": true,
    "supportsFinetuning": true,
    "tier": "advanced"
