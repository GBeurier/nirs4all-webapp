  {
    "id": "preprocessing.cars",
    "name": "CARS",
    "type": "preprocessing",
    "classPath": "nirs4all.operators.transforms.CARS",
    "description": "Competitive Adaptive Reweighted Sampling",
    "longDescription": "Variable selection method that uses PLS to iteratively select important wavelengths.",
