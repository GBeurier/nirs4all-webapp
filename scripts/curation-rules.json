  "finetuningRules": {
    "$comment": "Auto-assign finetuning based on param name patterns",
    "n_components": { "finetuneType": "int", "range": [1, 30] },
    "n_estimators": { "finetuneType": "int", "range": [10, 500] },
    "max_depth": { "finetuneType": "int", "range": [2, 30] },
    "alpha": { "finetuneType": "float", "range": [0.0001, 10.0] },
    "C": { "finetuneType": "float", "range": [0.01, 100.0] },
    "epsilon": { "finetuneType": "float", "range": [0.001, 1.0] },
    "gamma": { "finetuneType": "float", "range": [0.001, 10.0] },
    "learning_rate": { "finetuneType": "float", "range": [0.001, 1.0] },
    "n_neighbors": { "finetuneType": "int", "range": [1, 30] },
    "l1_ratio": { "finetuneType": "float", "range": [0.0, 1.0] },
    "min_samples_leaf": { "finetuneType": "int", "range": [1, 20] },
    "min_samples_split": { "finetuneType": "int", "range": [2, 20] },
    "subsample": { "finetuneType": "float", "range": [0.5, 1.0] },
    "n_clusters": { "finetuneType": "int", "range": [2, 20] },
    "perplexity": { "finetuneType": "float", "range": [5, 50] },
    "n_bins": { "finetuneType": "int", "range": [2, 20] },
    "degree": { "finetuneType": "int", "range": [2, 5] },
    "n_knots": { "finetuneType": "int", "range": [3, 20] }
  },

