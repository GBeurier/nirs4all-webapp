{
  "$comment": "Rules for curating canonical registry nodes into definition files",

  "excludeParams": [
    "copy", "copy_X", "verbose", "n_jobs", "warm_start",
    "presort", "class_weight", "max_samples", "oob_score",
    "monotonic_cst", "min_weight_fraction_leaf"
  ],

  "alwaysAdvanced": [
    "random_state", "tol", "max_iter", "algorithm",
    "n_iter", "n_iter_no_change", "validation_fraction"
  ],

  "primaryParams": {
    "model": [
      "n_components", "n_estimators", "max_depth", "alpha", "C", "epsilon",
      "kernel", "n_neighbors", "learning_rate", "criterion", "loss",
      "gamma", "degree", "solver", "penalty", "l1_ratio", "min_samples_leaf",
      "min_samples_split", "subsample", "max_features", "n_layers",
      "hidden_layer_sizes", "activation"
    ],
    "preprocessing": [
      "n_components", "n_clusters", "threshold", "with_mean", "with_std",
      "with_centering", "with_scaling", "strategy", "n_neighbors",
      "feature_range", "norm", "n_bins", "encode", "degree", "n_knots",
      "method", "whiten", "perplexity"
    ],
    "splitting": [
      "n_splits", "test_size", "n_repeats", "shuffle", "n_groups", "p",
      "max_train_size", "gap"
    ],
    "y_processing": [
      "with_mean", "with_std", "n_bins", "strategy"
    ]
  },

  "typeConversions": {
    "kernel": {
      "type": "select",
      "options": [
        { "value": "rbf", "label": "RBF" },
        { "value": "linear", "label": "Linear" },
        { "value": "poly", "label": "Polynomial" },
        { "value": "sigmoid", "label": "Sigmoid" }
      ]
    },
    "solver": {
      "type": "select",
      "options": [
        { "value": "auto", "label": "Auto" },
        { "value": "svd", "label": "SVD" },
        { "value": "lsqr", "label": "LSQR" },
        { "value": "saga", "label": "SAGA" },
        { "value": "lbfgs", "label": "L-BFGS" },
        { "value": "adam", "label": "Adam" },
        { "value": "sgd", "label": "SGD" }
      ]
    },
    "criterion": {
      "type": "select",
      "options": [
        { "value": "squared_error", "label": "Squared Error" },
        { "value": "friedman_mse", "label": "Friedman MSE" },
        { "value": "absolute_error", "label": "Absolute Error" },
        { "value": "poisson", "label": "Poisson" },
        { "value": "gini", "label": "Gini" },
        { "value": "entropy", "label": "Entropy" },
        { "value": "log_loss", "label": "Log Loss" }
      ]
    },
    "loss": {
      "type": "select",
      "options": [
        { "value": "squared_error", "label": "Squared Error" },
        { "value": "absolute_error", "label": "Absolute Error" },
        { "value": "huber", "label": "Huber" },
        { "value": "quantile", "label": "Quantile" },
        { "value": "log_loss", "label": "Log Loss" },
        { "value": "hinge", "label": "Hinge" }
      ]
    },
    "penalty": {
      "type": "select",
      "options": [
        { "value": "l1", "label": "L1 (Lasso)" },
        { "value": "l2", "label": "L2 (Ridge)" },
        { "value": "elasticnet", "label": "Elastic Net" },
        { "value": "none", "label": "None" }
      ]
    },
    "activation": {
      "type": "select",
      "options": [
        { "value": "relu", "label": "ReLU" },
        { "value": "identity", "label": "Identity" },
        { "value": "logistic", "label": "Logistic" },
        { "value": "tanh", "label": "Tanh" }
      ]
    },
    "strategy": {
      "type": "select",
      "options": [
        { "value": "mean", "label": "Mean" },
        { "value": "median", "label": "Median" },
        { "value": "most_frequent", "label": "Most Frequent" },
        { "value": "constant", "label": "Constant" },
        { "value": "uniform", "label": "Uniform" },
        { "value": "quantile", "label": "Quantile" },
        { "value": "kmeans", "label": "KMeans" }
      ]
    },
    "norm": {
      "type": "select",
      "options": [
        { "value": "l1", "label": "L1" },
        { "value": "l2", "label": "L2" },
        { "value": "max", "label": "Max" }
      ]
    },
    "encode": {
      "type": "select",
      "options": [
        { "value": "onehot", "label": "One-Hot" },
        { "value": "onehot-dense", "label": "One-Hot Dense" },
        { "value": "ordinal", "label": "Ordinal" }
      ]
    },
    "method": {
      "type": "select",
      "options": [
        { "value": "barnes_hut", "label": "Barnes-Hut" },
        { "value": "exact", "label": "Exact" }
      ]
    },
    "weights": {
      "type": "select",
      "options": [
        { "value": "uniform", "label": "Uniform" },
        { "value": "distance", "label": "Distance" }
      ]
    }
  },

  "duplicateMap": {
    "$comment": "Canonical IDs that are duplicates of existing curated nodes (different ID, different classPath)",
    "filter.metadata_filter": "filter.metadata",
    "filter.high_leverage_filter": "filter.high_leverage",
    "filter.x_outlier_filter": "filter.x_outlier",
    "filter.y_outlier_filter": "filter.y_outlier",
    "filter.spectral_quality_filter": "filter.spectral_quality",
    "preprocessing.air_pls": "preprocessing.airpls",
    "preprocessing.ar_pls": "preprocessing.arpls",
    "preprocessing.mod_poly": "preprocessing.modpoly",
    "preprocessing.i_mod_poly": "preprocessing.imodpoly",
    "preprocessing.py_baseline_correction": "preprocessing.baseline_correction",
    "preprocessing.local_standard_normal_variate": "preprocessing.local_snv",
    "preprocessing.robust_standard_normal_variate": "preprocessing.robust_snv",
    "preprocessing.extended_multiplicative_scatter_correction": "preprocessing.emsc",
    "preprocessing.resample_transformer": "preprocessing.resampler",
    "splitting.kennard_stone_splitter": "splitting.kennard_stone",
    "splitting.k_means_splitter": "splitting.kmeans_splitter",
    "splitting.s_plit_splitter": "splitting.split_splitter",
    "splitting.spxy_splitter": "splitting.spxy",
    "splitting.systematic_circular_splitter": "splitting.systematic_circular",
    "splitting.binned_stratified_group_k_fold": "splitting.binned_stratified_group_kfold",
    "splitting.k_bins_stratified_splitter": "splitting.kbins_stratified",
    "model.di_pls": "model.dipls"
  },

